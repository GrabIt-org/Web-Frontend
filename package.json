    "@tanstack/react-query": "^5.90.7",
    "@vis.gl/react-google-maps": "^1.7.1",
    "axios": "1.13.5",
    "dayjs": "^1.11.20",
    "pigeon-maps": "^0.22.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "tslib": "^2.8.1",
    "vite-plugin-pwa": "^1.1.0"
